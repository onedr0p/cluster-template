---
apiVersion: v1
kind: Pod
metadata:
  name: e2e-network-server
  namespace: default
  labels:
    app: e2e-network-server
spec:
  nodeName: "${E2E_WORKER_NODE}"
  containers:
    - name: server
      image: registry.k8s.io/e2e-test-images/agnhost:2.66.0
      args: ["netexec", "--http-port=8080"]
      ports:
        - name: http
          containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: e2e-network-server
  namespace: default
spec:
  selector:
    app: e2e-network-server
  ports:
    - name: http
      port: 8080
      targetPort: http
---
apiVersion: v1
kind: Pod
metadata:
  name: e2e-network-client
  namespace: default
spec:
  nodeName: "${E2E_CONTROLPLANE_NODE}"
  containers:
    - name: client
      image: registry.k8s.io/e2e-test-images/agnhost:2.66.0
      args: ["pause"]
